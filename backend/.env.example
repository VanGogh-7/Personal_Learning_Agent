APP_NAME=Personal Learning Agent
APP_ENV=development
APP_VERSION=0.1.0
LLM_PROVIDER=deterministic
EMBEDDING_PROVIDER=mock
WEB_RESEARCH_PROVIDER=none
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_BASE_URL=https://api.tavily.com/search
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5
TAVILY_CONNECT_TIMEOUT_SECONDS=10
TAVILY_READ_TIMEOUT_SECONDS=30
BRAVE_API_KEY=

# Controlled MCP research. External server packages must be installed explicitly;
# the default npx commands use --no-install.
MCP_ENABLED=false
MCP_REAL_TESTS=false
MCP_CONNECT_TIMEOUT_SECONDS=10
MCP_TOOL_TIMEOUT_SECONDS=30
MCP_TOTAL_TIMEOUT_SECONDS=45
MCP_MAX_RETRIES=1
MCP_RETRY_BACKOFF_SECONDS=0.2
MCP_MAX_PENDING_CALLS_PER_SERVER=20
MCP_MAX_CALLS_PER_REQUEST=6
MCP_MAX_EVIDENCE=10
MCP_MAX_FETCH_URLS=3
# Stage 57 corrective retrieval shares this request budget and is code-bounded
# to one retry by default; it does not expose a user-configurable Agent loop.

MCP_TAVILY_TRANSPORT=stdio
MCP_TAVILY_URL=https://mcp.tavily.com/mcp
MCP_TAVILY_COMMAND=npx
MCP_TAVILY_ARGS=["--no-install","tavily-mcp"]

MCP_BRAVE_TRANSPORT=stdio
MCP_BRAVE_URL=
MCP_BRAVE_COMMAND=npx
MCP_BRAVE_ARGS=["--no-install","@brave/brave-search-mcp-server","--transport","stdio"]

MCP_FETCH_TRANSPORT=stdio
MCP_FETCH_URL=
MCP_FETCH_COMMAND=python
MCP_FETCH_ARGS=["-m","app.mcp.servers.fetch"]
MCP_FETCH_MAX_RESPONSE_BYTES=1000000
MCP_FETCH_MAX_CONTENT_CHARACTERS=12000
MCP_FETCH_MAX_REDIRECTS=3
MCP_FETCH_READ_TIMEOUT_SECONDS=15
MCP_FETCH_TOTAL_TIMEOUT_SECONDS=30

MCP_ACADEMIC_TRANSPORT=stdio
MCP_ACADEMIC_URL=
MCP_ACADEMIC_COMMAND=python
MCP_ACADEMIC_ARGS=["-m","app.mcp.servers.academic"]
ACADEMIC_API_TIMEOUT_SECONDS=20
ACADEMIC_API_MIN_INTERVAL_SECONDS=0.2
ACADEMIC_API_USER_AGENT=PersonalLearningAgent/0.1
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_CONNECT_TIMEOUT_SECONDS=10
LLM_READ_TIMEOUT_SECONDS=60
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSION=1024
EMBEDDING_CONNECT_TIMEOUT_SECONDS=10
EMBEDDING_READ_TIMEOUT_SECONDS=60
# Desktop Provider profiles override these fallbacks for new requests after the
# Tauri Stronghold vault is unlocked. The Settings page never writes API keys
# into this file; it remains development-only fallback configuration.
AGENT_LATENCY_LOGGING_ENABLED=true
AGENT_DEBUG_TIMINGS_IN_RESPONSE=false
AGENT_STREAMING_ENABLED=true
AGENT_ACTIVITY_EVENTS_ENABLED=true
AGENT_STREAM_UI_FLUSH_INTERVAL_MS=50
AGENT_STREAM_HEARTBEAT_SECONDS=15
PLA_REAL_PROVIDER_TESTS=false
# Stage 58/59 real QueryAnalysis, MCP, grader, and semantic-verifier evaluations
# also require explicit CLI confirmation. Default pytest and runners stay offline.
PLA_REAL_PROVIDER_BENCHMARK_RUNS=10
PLA_REAL_PROVIDER_WARMUP_RUNS=1
PLA_SSE_SOAK_RUNS=20
PLA_SSE_TARGET_URL=http://127.0.0.1:8081
PLA_SSE_PROXY_TARGET_URL=
PLA_LONG_ANSWER_MAX_TOKENS=2000
PLA_FAULT_INJECTION_ENABLED=false
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/personal_learning_agent
LIBRARY_STORAGE_DIR=storage/library
PDF_OCR_ENABLED=true
PDF_OCR_LANGUAGE=eng
PDF_OCR_OUTPUT_DIR=storage/ocr
PDF_LAYOUT_PARSER=pymupdf_rule
PDF_TEXT_HYBRID_RETRIEVAL_ENABLED=true
# Experimental only. No visual model is downloaded automatically.
PDF_VISUAL_RETRIEVAL_ENABLED=false
PDF_VISUAL_MODEL=mock-colpali
PDF_VISUAL_DIMENSION=128
PDF_HYBRID_DENSE_WEIGHT=1.0
PDF_HYBRID_KEYWORD_WEIGHT=1.0
PDF_HYBRID_VISUAL_WEIGHT=0.7
LOCAL_EXACT_SEARCH_MAX_DOCUMENTS=5
HNSW_EF_SEARCH=40
MEMORY_CHECKPOINTER_BACKEND=postgres
MEMORY_RECENT_TURN_LIMIT=16
MEMORY_SUMMARY_TRIGGER_TURNS=24
MEMORY_RETRIEVAL_LIMIT=5
MEMORY_AUTO_WRITE_ENABLED=true
MEMORY_AUTO_WRITE_MIN_IMPORTANCE=0.75
MEMORY_AUTO_WRITE_MIN_CONFIDENCE=0.80
MEMORY_AUTO_WRITE_MIN_DURABILITY=0.75
MEMORY_DEFAULT_NAMESPACE=default_user
MEMORY_PROJECT_NAMESPACE=project:personal-learning-agent
MEMORY_POSTGRES_POOL_MIN_SIZE=1
MEMORY_POSTGRES_POOL_MAX_SIZE=10
