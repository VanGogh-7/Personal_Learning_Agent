{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal Learning Agent",
  "version": "0.1.0",
  "identifier": "dev.personal-learning-agent.app",
  "build": {
    "beforeDevCommand": "bun run dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build:vite",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": false,
    "icon": []
  },
  "app": {
    "windows": [
      {
        "title": "Personal Learning Agent",
        "width": 1100,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; worker-src 'self' blob:; connect-src http://127.0.0.1:8081 http://localhost:8081 ws://127.0.0.1:1420 ws://localhost:1420"
    }
  }
}
