{
  "identifier": "default",
  "description": "Default desktop capability for PDF import and safe external URLs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "stronghold:default",
    "stronghold:allow-remove-store-record",
    "dialog:allow-open",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }, { "url": "http://*" }]
    }
  ]
}
