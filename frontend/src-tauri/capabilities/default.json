{
  "identifier": "default",
  "description": "Default desktop capability for importing and opening managed PDFs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**/*.pdf" }]
    }
  ]
}
